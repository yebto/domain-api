{
    "name": "yebto/domain-api",
    "description": "PHP SDK for the YEB Domain API. Domain analysis, niche and category detection.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "yeb",
        "api",
        "sdk",
        "laravel",
        "php",
        "domain",
        "dns",
        "niche",
        "seo"
    ],
    "homepage": "https://yeb.to",
    "support": {
        "email": "support@yeb.to",
        "issues": "https://github.com/yebto/domain-api/issues",
        "source": "https://github.com/yebto/domain-api"
    },
    "authors": [
        {
            "name": "NETOX Ltd.",
            "email": "support@yeb.to",
            "homepage": "https://yeb.to",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "yebto/api-client": "^1.0"
    },
    "suggest": {
        "illuminate/support": "Required for Laravel Facade & ServiceProvider integration (^10.0|^11.0|^12.0)"
    },
    "autoload": {
        "psr-4": {
            "Yebto\\DomainAPI\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Yebto\\DomainAPI\\DomainAPIServiceProvider"
            ],
            "aliases": {
                "DomainAPI": "Yebto\\DomainAPI\\Facades\\DomainAPI"
            }
        }
    }
}
